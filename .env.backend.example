APP_VERSION=1.0.0
HTTP_ADDRESS=:8080
DATABASE_URL=postgres://appclimb_runtime:replace-me@db:5432/appclimb?sslmode=disable
JWT_SIGNING_KEY_B64=base64-encoded-random-key-at-least-32-bytes
ENVELOPE_MASTER_KEY=base64-encoded-random-32-byte-key
INTERNAL_TOKEN=random-token-at-least-32-characters
PADDLE_WEBHOOK_SECRET=replace-me
ALLOWED_ORIGINS=https://appclimb.app
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
SYNC_INTERVAL=6h
HISTORY_DAYS=90
